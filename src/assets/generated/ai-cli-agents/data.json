erformance assistant for code, research, and general automation tasks."},{"type":"header","level":2,"content":"General Info","children":[]},{"type":"header","level":2,"content":"Vendor","children":[{"type":"list","level":2,"children":[{"type":"item","level":1,"content":"Agentic AI Foundation","plainChildren":""}]}]},{"type":"header","level":2,"content":"License","children":[{"type":"list","level":2,"children":[{"type":"item","level":1,"content":"Apache-2.0","plainChildren":""}]}]},{"type":"header","level":2,"content":"Open Source","children":[{"type":"list","level":2,"children":[{"type":"item","level":1,"content":"Yes","plainChildren":""}]}]},{"type":"header","level":2,"content":"Capabilities","children":[]},{"type":"header","level":2,"content":"Interface Type","children":[{"type":"list","level":2,"children":[{"type":"item","level":1,"content":"Desktop App","plainChildren":""},{"type":"item","level":1,"content":"CLI","plainChildren":""},{"type":"item","level":1,"content":"API","plainChildren":""}]}]},{"type":"header","level":2,"content":"Platform Support","children":[{"type":"list","level":2,"children":[{"type":"item","level":1,"content":"MacOS","plainChildren":""},{"type":"item","level":1,"content":"Linux","plainChildren":""},{"type":"item","level":1,"content":"Windows","plainChildren":""}]}]},{"type":"header","level":2,"content":"Model Providers","children":[{"type":"list","level":2,"children":[{"type":"item","level":1,"content":"Anthropic","plainChildren":""},{"type":"item","level":1,"content":"OpenAI","plainChildren":""},{"type":"item","level":1,"content":"Google","plainChildren":""},{"type":"item","level":1,"content":"Ollama","plainChildren":""},{"type":"item","level":1,"content":"OpenRouter","plainChildren":""},{"type":"item","level":1,"content":"Azure","plainChildren":""},{"type":"item","level":1,"content":"Bedrock","plainChildren":""}]}]},{"type":"header","level":2,"content":"Authentication","children":[{"type":"list","level":2,"children":[{"type":"item","le